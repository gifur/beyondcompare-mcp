{
  "name": "beyondcompare-mcp",
  "version": "0.1.0",
  "description": "Modern MCP server for Beyond Compare file and directory comparison with multimedia drive scanning",
  "author": "Sandra Schi",
  "license": "MIT",
  "outputDir": "dist",
  "mcp": {
    "version": "2.12.0",
    "server": {
      "command": "python",
      "args": ["-m", "beyondcompare_mcp"],
      "transport": "stdio"
    },
    "capabilities": {
      "tools": true,
      "resources": false,
      "prompts": false
    }
  },
  "dependencies": {
    "python": ">=3.10.0",
    "fastmcp": ">=2.12.0",
    "pydantic": ">=2.5.0",
    "python-dotenv": ">=1.0.0",
    "anyio": ">=4.0.0",
    "structlog": ">=23.0.0"
  }
}
