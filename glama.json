{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": ["sandraschi"],
  "name": "beyondcompare-mcp",
  "description": "MCP 2.11+ server for file comparison, multimedia management, and developer workspace tools using Beyond Compare. 13 tools for comparison, sync, diff reports, and code analysis. Beta status.",
  "type": "mcp_server",
  "status": "beta",
  "framework": "MCP 2.11+",
  "tools": 13,
  "transport": ["stdio"],
  "keywords": [
    "beyond-compare",
    "file-comparison",
    "diff",
    "synchronization",
    "multimedia",
    "workspace-tools",
    "mcp-server"
  ],
  "features": {
    "file_comparison": {
      "enabled": true
    },
    "directory_sync": {
      "enabled": true,
      "modes": ["mirror", "update", "backup"]
    },
    "diff_reports": {
      "enabled": true
    },
    "multimedia_management": {
      "enabled": true
    },
    "workspace_tools": {
      "enabled": true,
      "features": ["repository_backup", "health_scanning", "code_analysis"]
    }
  }
}

